// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum ProcessingMode {
  FULL_TEXT // Raw extracted text sent to TTS
  SUMMARY // AI-shortened version
  PODCAST // AI-rewritten conversational style
}

enum DocumentStatus {
  UPLOADED // File stored, not yet processed
  EXTRACTING // PDF text extraction in progress
  CHUNKING // Splitting into TTS chunks
  REWRITING // AI rewriting in progress (before audio generation)
  GENERATING // TTS generating audio, nothing playable yet
  PARTIALLY_READY // Some audio chunks are ready — playable, still generating
  READY // All audio chunks generated, fully playable
  ERROR // Something went wrong
}

enum ChunkStatus {
  PENDING // Created, waiting for audio generation
  GENERATING_AUDIO // TTS is running for this chunk
  DONE // Audio generated and uploaded to S3
  ERROR // Audio generation failed
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isPremium Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents        Document[]
  playbackProgress PlaybackProgress[]

  @@map("users")
}

model Document {
  id              String         @id @default(cuid())
  title           String
  fileName        String // original filename
  fileUrl         String // path on disk or object storage URL
  fileSize        Int? // bytes
  pageCount       Int?
  extractedText   String?        @db.Text
  language        String         @default("en")
  status          DocumentStatus @default(UPLOADED)
  audioDuration   Float? // Total audio duration in seconds (for FULL_TEXT mode)
  totalChunks     Int            @default(0) // Total FULL_TEXT chunks expected
  processedChunks Int            @default(0) // Chunks with status = DONE
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Error tracking (populated when status = ERROR)
  errorMessage String? // Human-readable error description
  errorCode    String? // Machine-readable error code (PDF_PARSE_FAILED, etc.)
  failedAt     DateTime? // Timestamp when error occurred

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chunks           TextChunk[]
  audioChunks      AudioChunk[]
  playbackProgress PlaybackProgress[]

  // Performance indexes
  @@index([userId, createdAt(sort: Desc)]) // Dashboard: user's documents, newest first
  @@index([status]) // Find documents by status (ERROR, READY, etc.)
  @@index([createdAt]) // Admin queries and cleanup tasks
  @@map("documents")
}

// Each chunk is a segment of text (500–1200 tokens) ready for TTS.
// Storing chunks in DB lets us:
//   1. Resume from exact chunk position
//   2. Cache audio per chunk + mode (avoid re-running Piper)
//   3. Know which chunks have been AI-processed
model TextChunk {
  id            String         @id @default(cuid())
  index         Int // 0-based order within document
  text          String         @db.Text // original extracted text for this chunk
  tokenCount    Int?
  mode          ProcessingMode @default(FULL_TEXT)
  processed     String?        @db.Text // AI-rewritten text (null = not yet processed)
  audioPath     String? // path to cached .wav file on disk
  audioDuration Float? // Duration of this chunk's audio in seconds (unused — see AudioChunk.duration)
  status        ChunkStatus    @default(PENDING) // Lifecycle state for audio generation
  createdAt     DateTime       @default(now())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, index, mode]) // one cached audio per (doc, chunk, mode)
  @@map("text_chunks")
}

// Each AudioChunk represents a generated audio file stored in S3.
// Used to avoid re-generating TTS audio for the same chunk.
model AudioChunk {
  id        String   @id @default(cuid())
  s3Key     String // S3 object key, e.g. "audio/{docId}/chunk-{index}.wav"
  s3Url     String // Full public URL for direct playback
  duration  Float? // Audio duration in seconds (parsed from WAV header)
  textHash  String? // SHA-256 of the text used to generate this audio; null = legacy record
  createdAt DateTime @default(now())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int // Matches TextChunk.index (0-based)

  @@unique([documentId, chunkIndex])
  @@index([documentId, chunkIndex])
  @@map("audio_chunks")
}

// Stores where the user stopped listening.
// Free users: this table is unused — they use localStorage.
// Premium users: this table is used — enables cross-device resume.
model PlaybackProgress {
  id         String         @id @default(cuid())
  time       Float // seconds into the full audio
  chunkIndex Int            @default(0) // which chunk was playing
  mode       ProcessingMode @default(FULL_TEXT)
  updatedAt  DateTime       @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId]) // one progress record per (user, document)
  @@index([userId, documentId, mode]) // Fast progress lookup
  @@index([updatedAt]) // Analytics and cleanup queries
  @@map("playback_progress")
}
